{
  "private": true,
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --minify --outfile=dist/app.js --loader:.tsx=tsx --loader:.ts=ts && ./node_modules/.bin/tailwindcss -i src/index.css -o dist/styles.css --minify",
    "watch": "esbuild src/index.tsx --bundle --outfile=dist/app.js --loader:.tsx=tsx --loader:.ts=ts --watch & ./node_modules/.bin/tailwindcss -i src/index.css -o dist/styles.css --watch",
    "build:js": "esbuild src/index.tsx --bundle --minify --outfile=dist/app.js --loader:.tsx=tsx --loader:.ts=ts",
    "build:css": "./node_modules/.bin/tailwindcss -i src/index.css -o dist/styles.css --minify",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\""
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/cli": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "esbuild": "^0.27.4",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10",
    "rehype-sanitize": "^6",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0"
  }
}
